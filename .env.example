# ─────────────────────────────────────────────────────────────────────────────
# Suri APP (client) env template. Copy to .env and fill in:
#   cp .env.example .env
# .env is gitignored; this template is safe to commit.
#
# The app holds NO LLM provider keys. Those are SERVER-SIDE secrets — see
# supabase/functions/suri-ai-proxy/.env.example. The client only needs the proxy
# URL and the access token below.
# ─────────────────────────────────────────────────────────────────────────────

# Edge Function URL (deployed) or local `supabase functions serve` endpoint.
#   Android emulator: http://10.0.2.2:54321/functions/v1/suri-ai-proxy
#   Deployed:         https://<project-ref>.supabase.co/functions/v1/suri-ai-proxy
EXPO_PUBLIC_PROXY_URL=

# Access token the client sends to the proxy. Equals PROXY_SHARED_SECRET in the
# server .env (with --no-verify-jwt), or the Supabase anon key (with JWT verify).
EXPO_PUBLIC_PROXY_TOKEN=
# ─────────────────────────────────────────────────────────────────────────────
# OPTIONAL — direct (client-side) provider keys for the named cloud cascade
# (Gemini → Groq → OpenRouter). Set these to call the providers DIRECTLY from
# the app, instead of (or ahead of) the server proxy above. Leave blank to skip
# a tier; with all blank, Suri uses the proxy (if set), then cache + on-device.
#
# ⚠ SECURITY: EXPO_PUBLIC_* values are INLINED into the JS bundle, so these keys
# are visible in the shipped APK. That is acceptable ONLY for FREE-tier keys per
# the current project decision. The server proxy remains the safer production
# path — keep any billable/secret key server-side (supabase/functions/.env).
# ─────────────────────────────────────────────────────────────────────────────

# Google Gemini API key (OpenAI-compatible endpoint). Primary tier.
EXPO_PUBLIC_GEMINI_API_KEY=

# Groq API key. Fallback 1.
EXPO_PUBLIC_GROQ_API_KEY=

# OpenRouter API key. Fallback 2.
EXPO_PUBLIC_OPENROUTER_API_KEY=
