{
  "name": "suri",
  "version": "0.1.0",
  "main": "expo-router/entry",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "typecheck": "tsc --noEmit",
    "verify:schema": "node scripts/verify-schema.mjs",
    "verify:profile": "node --import ./scripts/register-ts.mjs scripts/verify-profile.mjs",
    "verify:rag": "node --import ./scripts/register-ts.mjs scripts/verify-rag.mjs",
    "verify:router": "node --import ./scripts/register-ts.mjs scripts/verify-router.mjs",
    "verify:slm": "node --import ./scripts/register-ts.mjs scripts/verify-slm.mjs",
    "verify:services": "node --import ./scripts/register-ts.mjs scripts/verify-services.mjs",
    "verify:telemetry": "node --import ./scripts/register-ts.mjs scripts/verify-telemetry.mjs",
    "verify:gamification": "node --import ./scripts/register-ts.mjs scripts/verify-gamification.mjs",
    "verify:kwento": "node --import ./scripts/register-ts.mjs scripts/verify-kwento.mjs",
    "verify:misconception": "node --import ./scripts/register-ts.mjs scripts/verify-misconception.mjs",
    "verify:kasabay": "node --import ./scripts/register-ts.mjs scripts/verify-kasabay.mjs",
    "verify:ocr": "node --import ./scripts/register-ts.mjs scripts/verify-ocr.mjs",
    "verify": "npm run verify:schema && npm run verify:profile && npm run verify:rag && npm run verify:router && npm run verify:slm && npm run verify:services && npm run verify:telemetry && npm run verify:gamification && npm run verify:kwento && npm run verify:misconception && npm run verify:kasabay && npm run verify:ocr",
    "test": "jest",
    "test:ci": "jest --ci --runInBand"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.3",
    "@react-native-community/netinfo": "~11.4.0",
    "@react-native-ml-kit/text-recognition": "^2.0.0",
    "expo": "~54.0.0",
    "expo-av": "~16.0.0",
    "expo-background-fetch": "~14.0.9",
    "expo-camera": "~17.0.10",
    "expo-constants": "~18.0.13",
    "expo-file-system": "~19.0.0",
    "expo-font": "~14.0.12",
    "expo-linking": "~8.0.12",
    "expo-router": "~6.0.0",
    "expo-secure-store": "~15.0.0",
    "expo-speech": "~14.0.0",
    "expo-speech-recognition": "~2.1.0",
    "expo-sqlite": "~16.0.0",
    "expo-status-bar": "~3.0.0",
    "expo-task-manager": "~14.0.9",
    "llama.rn": "0.12.5",
    "react": "19.1.0",
    "react-native": "0.81.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.11.0",
    "react-native-svg": "15.12.1",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^29.5.14",
    "@types/react": "~19.1.0",
    "babel-preset-expo": "~54.0.11",
    "jest": "~29.7.0",
    "jest-expo": "~54.0.17",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.8.0"
  },
  "overrides": {
    "react-dom": "19.1.0"
  },
  "private": true
}
