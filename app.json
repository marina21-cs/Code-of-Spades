{
  "expo": {
    "name": "Suri",
    "slug": "suri",
    "scheme": "suri",
    "version": "0.1.0",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "android": {
      "package": "ph.suri.app"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "ph.suri.app"
    },
    "plugins": [
      "expo-router",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
