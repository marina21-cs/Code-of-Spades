# ─────────────────────────────────────────────────────────────────────────────
# Suri AI Proxy — SERVER-SIDE secrets (NEVER shipped to the client)
#
# Local dev:   supabase functions serve suri-ai-proxy --env-file ./supabase/functions/suri-ai-proxy/.env
# Production:  supabase secrets set GEMINI_API_KEY=... GROQ_API_KEY=... OPENROUTER_API_KEY=...
#
# These are the real, billable/quota'd provider keys. They live ONLY here.
# ─────────────────────────────────────────────────────────────────────────────

# Cascade tier 1 — primary
GEMINI_API_KEY=

# Cascade tier 1 — fallback 1
GROQ_API_KEY=

# Cascade tier 1 — fallback 2
OPENROUTER_API_KEY=

# Optional: a non-JWT shared secret the client must present (x-suri-proxy-secret
# header or Authorization: Bearer <secret>). Only needed if you deploy with
# `--no-verify-jwt`. If you instead authenticate with the Supabase anon key,
# leave this blank — SUPABASE_ANON_KEY is injected automatically by the platform.
PROXY_SHARED_SECRET=

# NOTE: SUPABASE_URL, SUPABASE_ANON_KEY and SUPABASE_SERVICE_ROLE_KEY are
# provided automatically in the deployed Edge runtime — do NOT set them here.
